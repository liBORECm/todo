<!DOCTYPE html>
<html>

<head>
  <meta charset="utf-8" />

  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f3f3f3;
      margin: 0;
      padding: 40px;
      display: flex;
      justify-content: center;
    }

    .wrapper {
      background: white;
      padding: 30px 40px;
      border-radius: 12px;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.12);
      min-width: 300px;
      text-align: center;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 20px;
    }

    th,
    td {
      padding: 10px;
      border-bottom: 1px solid #ddd;
    }

    th {
      background: #fafafa;
      font-weight: bold;
    }

    tr:hover td {
      background: #f0f7ff;
    }

    h1 {
      margin: 0;
      font-size: 22px;
      color: #333;
    }
  </style>
</head>

<body>

  <div class="wrapper">
    <h1>Seznam to-do listů</h1>

    <table>
      <tbody>
        <% tables.forEach(function(table) { %>
        <tr onclick="window.location='/<%= table %>'" style="cursor: pointer;">
            <td><%= table %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

</body>

</html>